# Скопируй в .env и заполни.

# PostgreSQL. Локальный user-space инстанс поднимается через `npm run db:start`
# (порт 5433, без пароля). Можно указать любой другой сервер.
DATABASE_URL="postgresql://postgres@127.0.0.1:5433/personal_youtube"

# YouTube Data API v3 key (бесплатно): https://console.cloud.google.com/
YOUTUBE_API_KEY=

# Регион/язык выдачи
REGION_CODE=RU
RELEVANCE_LANGUAGE=ru
