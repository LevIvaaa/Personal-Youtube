# Скопируй этот файл в .env и впиши свой ключ:
#   cp .env.example .env
#
# YouTube Data API v3 key (бесплатно):
#   1. https://console.cloud.google.com/  -> создай проект
#   2. APIs & Services -> Library -> включи "YouTube Data API v3"
#   3. APIs & Services -> Credentials -> Create credentials -> API key
#   4. Вставь ключ ниже
YOUTUBE_API_KEY=

# Регион для трендов и языка выдачи
REGION_CODE=RU
RELEVANCE_LANGUAGE=ru

# Порт локального сервера
PORT=3000
